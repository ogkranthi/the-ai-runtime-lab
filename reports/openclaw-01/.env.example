# Copy to .env (gitignored) and fill with THROWAWAY keys. Set a hard spend cap on
# each key in the provider console before running. Suggested cap: 2 USD per key.

# Anthropic (issue 102323 primary, control elsewhere)
ANTHROPIC_API_KEY=

# OpenAI (issue 102321 primary, control elsewhere)
OPENAI_API_KEY=

# Gemini (issue 102320 primary, control elsewhere)
GEMINI_API_KEY=

# Local WebChat channel served by the compose network. Do not change unless you
# also change docker/compose.yml.
WEBCHAT_URL=http://localhost:8080

# The capture proxy the gateway forwards provider traffic through.
PROXY_HOST=proxy
PROXY_PORT=8081

# Where each repro writes captured evidence. Set per repro by repro.sh; this is
# only a default for manual runs.
CAPTURE_DIR=./evidence
